# Database
POSTGRES_DB=authdb
POSTGRES_USER=user
POSTGRES_PASSWORD=root
POSTGRES_PORT=5435

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Spring Boot
SPRING_DATASOURCE_URL=jdbc:postgresql://authdb:5432/authdb
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=root
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# JWT
APP_JWT_SECRET=super_strong_secret_for_jwt_signing
APP_JWT_ACCESS_EXPIRATION_MINUTES=15
APP_JWT_REFRESH_EXPIRATION_DAYS=7

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_SPRING_WEB=DEBUG
LOGGING_LEVEL_SPRING_SECURITY=DEBUG
LOGGING_LEVEL_HIBERNATE_SQL=DEBUG
LOGGING_LEVEL_HIBERNATE_TYPE_DESCRIPTOR_SQL_BASIC_BINDER=TRACE
